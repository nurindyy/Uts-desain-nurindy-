<div class="toast" id="toast"></div>

<script>
  // ══ NAVIGATION ══
  let navHistory = ['page-login'];

  function goTo(id) {
    const prev = document.querySelector('.page.active, .dash-page.active');
    const target = document.getElementById(id);
    if (!target || prev === target) return;

    if (prev) {
      prev.classList.remove('active');
      prev.style.display = 'none';
    }

    const isPage = target.classList.contains('page');
    target.style.display = isPage ? 'flex' : 'flex';
    target.classList.add('active');

    // Reset scroll
    const scroll = target.querySelector('.dash-scroll, .split-right, .chat-win-scroll');
    if (scroll) scroll.scrollTop = 0;

    if (navHistory[navHistory.length - 1] !== id) navHistory.push(id);
  }

  function goBack() {
    if (navHistory.length > 1) {
      const current = document.querySelector('.page.active, .dash-page.active');
      navHistory.pop();
      const prevId = navHistory[navHistory.length - 1];
      const prevPage = document.getElementById(prevId);
      if (current) { current.classList.remove('active'); current.style.display = 'none'; }
      if (prevPage) {
        const isPage = prevPage.classList.contains('page');
        prevPage.style.display = 'flex';
        prevPage.classList.add('active');
      }
    }
  }

  // ══ LOGIN ROLE ══
  let loginRole = 'pasien';
  function setLoginRole(r) {
    loginRole = r;
    ['pasien','ag','mandiri'].forEach(x => document.getElementById('login-tab-' + x).classList.toggle('active', x === r));
  }

  // ══ DAFTAR ROLE TABS ══
  function switchRole(role) {
    ['pasien','ag','mandiri'].forEach(r => {
      document.getElementById('tab-' + r).classList.toggle('active', r === role);
      document.getElementById('form-' + r).classList.toggle('active', r === role);
    });
  }

  // ══ USER DATA ══
  const userData = { nama: '', role: '' };

  function terapkanNama(role, nama) {
    if (role === 'pasien' || role === 'mandiri') {
      document.getElementById('dash-nama').textContent = nama + ' 👋';
      document.getElementById('profil-nama-pasien').textContent = nama;
    } else if (role === 'ag') {
      document.getElementById('dash-ag-nama').textContent = nama + ' 👩‍⚕️';
      document.getElementById('profil-nama-ag').textContent = nama;
    }
  }

  // ══ DAFTAR → langsung dashboard ══
  function daftar(role) {
    const namaId = role === 'pasien' ? 'p-nama' : role === 'ag' ? 'ag-nama' : 'm-nama';
    const nama = document.getElementById(namaId)?.value.trim();
    if (!nama) { showToast('Nama lengkap wajib diisi 🌸'); return; }
    userData.nama = nama; userData.role = role;
    terapkanNama(role, nama);
    showToast('Selamat datang, ' + nama + '! 🌸');
    goTo(role === 'ag' ? 'page-dash-ag' : 'page-dash-pasien');
  }

  // ══ LOGIN ══
  function loginDemo() {
    const email = document.getElementById('login-email')?.value.trim();
    if (!email) { showToast('Masukkan email kamu dulu ya 🌸'); return; }
    showToast('Memverifikasi akun...');
    setTimeout(() => masukSebagai(loginRole), 800);
  }

  function masukSebagai(role) {
    userData.role = role;
    goTo(role === 'ag' ? 'page-dash-ag' : 'page-dash-pasien');
  }

  // ══ BOTTOM NAV ══
  function setTab(el, pageId) {
    const nav = el.closest('.bottom-nav');
    nav.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');
    if (pageId) goTo(pageId);
  }

  // ══ CHAT ══
  function sendMsg(who) {
    const input = document.getElementById(who === 'pasien' ? 'msg-input-pasien' : 'msg-input-ag');
    const box   = document.getElementById(who === 'pasien' ? 'chatbox-pasien' : 'chatbox-ag');
    const text  = input.value.trim();
    if (!text) return;
    const now    = new Date().toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'});
    const sender = who === 'pasien' ? 'Aurelia' : 'Dr. Amara';
    const wrap   = document.createElement('div');
    wrap.className = 'bubble-wrap me';
    wrap.innerHTML = `<div class="bubble me">${text}</div><div class="bubble-time">${sender} · ${now}</div>`;
    box.appendChild(wrap);
    input.value = '';
    box.scrollTop = box.scrollHeight;
    setTimeout(() => {
      const replies = ['Baik, saya catat ya 📝','Terima kasih infonya! 🌸','Oke, akan saya evaluasi.','Bagus sekali! 💪','Tetap semangat! 🌟'];
      const r = document.createElement('div');
      r.className = 'bubble-wrap them';
      const rname = who === 'pasien' ? 'Dr. Amara' : 'Aurelia';
      r.innerHTML = `<div class="bubble them">${replies[Math.floor(Math.random()*replies.length)]}</div><div class="bubble-time">${rname} · ${new Date().toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'})}</div>`;
      box.appendChild(r);
      box.scrollTop = box.scrollHeight;
    }, 1200);
  }

  // ══ TOAST ══
  let toastTimer;
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
  }
</script>
</body>
